# ServiceBridge AI environment variables
# Copy this file to .env.local and fill in your own values.
# Do not commit .env.local or real API keys.

# Optional: enables OpenAI-powered chatbot/guidance responses.
# The app still runs with grounded local fallback when this is missing.
OPENAI_API_KEY=

# Optional: Firebase/Firestore public config for service records and feedback.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: Google Maps browser key if you later embed a live map.
# Current MVP can use safe Google Maps search links without this key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
